{
  "name": "@blazion/core",
  "version": "1.0.0",
  "description": "Core engine for Blazion — a lightweight, strictly-typed fetch wrapper",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "blazion",
    "fetch",
    "http",
    "api",
    "typescript",
    "zero-dependency"
  ],
  "scripts": {
    "build": "tsc --build && tsup",
    "lint": "eslint src --fix"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
